{
  "name": "trianglelist-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync-wasm": "node scripts/sync-wasm.mjs",
    "sync-icons": "node scripts/sync-icons.mjs",
    "dev": "npm run sync-wasm && npm run sync-icons && vite",
    "build": "npm run sync-wasm && npm run sync-icons && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --no-file-parallelism",
    "test:fast": "vitest run --no-file-parallelism --exclude \"**/chain-interactive.test.ts\" --exclude \"**/kind-toggle.test.ts\"",
    "test:ui": "vitest run --no-file-parallelism test/chain-interactive.test.ts test/kind-toggle.test.ts",
    "test:combo": "vitest run test/combo-pair.test.ts",
    "test:chain": "vitest run test/chain-coverage.test.ts"
  },
  "devDependencies": {
    "@types/encoding-japanese": "^2.2.1",
    "playwright": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@zumer/snapdom": "^2.12.8",
    "dxf-viewer": "^1.0.48",
    "encoding-japanese": "^2.2.0",
    "exceljs": "^4.4.0"
  }
}
